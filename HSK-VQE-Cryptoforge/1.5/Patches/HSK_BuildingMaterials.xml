    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VQE_BustedShieldedTurret"]/costList/Steel</xpath>
        <value><SteelBar>20</SteelBar></value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VQE_BustedSpacerAutocannon"]/costList/Steel</xpath>
        <value><SteelBar>20</SteelBar></value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VQE_FrozenCryptoRailcannon"]/costList/Steel</xpath>
        <value><SteelBar>100</SteelBar></value>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VQE_AncientShipLandingBeacon"]/costList/Steel</xpath>
        <value><SteelBar>20</SteelBar></value>
    </Operation>

    <Operation Class="PatchOperationReplace">
