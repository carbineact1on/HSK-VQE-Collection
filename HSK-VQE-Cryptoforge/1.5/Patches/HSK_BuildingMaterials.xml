<?xml version="1.0" encoding="utf-8" ?>
<!-- HSK material swaps for VQE Cryptoforge buildings -->
<Patch>

    <!-- ================================================================ -->
    <!--  CRYPTOPODS (Steel + Uranium — full pair swap)                    -->
    <!-- ================================================================ -->

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VQE_FrozenEmptyCryptosleepPod"]/costList/Steel</xpath>
        <value><SteelBar>50</SteelBar></value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VQE_FrozenEmptyCryptosleepPod"]/costList/Uranium</xpath>
        <value><DepletedUranium>6</DepletedUranium></value>
    </Operation>

