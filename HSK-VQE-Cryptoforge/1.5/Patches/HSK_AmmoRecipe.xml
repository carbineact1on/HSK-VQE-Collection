<?xml version="1.0" encoding="utf-8" ?>
<!--
    HSK overlay on the bundled CE crypto bolt ammo recipe.

    Upstream CE recipe (VQEC_Ammo_Cryptoforge.xml) uses raw <Steel> as
    an ingredient. HSK's economy converts raw Steel into SteelBar at
    the smelter — so the recipe should consume SteelBar instead.

    This patch swaps the Steel ingredient + the fixed ingredient filter
    entry to SteelBar, leaving Plasteel + ComponentIndustrial as-is
    (both already HSK-native).
-->
<Patch>

    <!-- Replace the Steel ingredient block (count 10) with SteelBar -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/RecipeDef[defName="MakeAmmo_VQEC_CryptoBolt"]/ingredients/li[filter/thingDefs/li="Steel"]</xpath>
        <value>
            <li>
                <filter>
                    <thingDefs>
                        <li>SteelBar</li>
                    </thingDefs>
                </filter>
                <count>10</count>
            </li>
        </value>
    </Operation>

    <!-- Replace the fixedIngredientFilter entry: Steel → SteelBar -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/RecipeDef[defName="MakeAmmo_VQEC_CryptoBolt"]/fixedIngredientFilter/thingDefs/li[text()="Steel"]</xpath>
        <value>
            <li>SteelBar</li>
        </value>
    </Operation>

</Patch>
